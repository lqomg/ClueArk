
# 首次部署/重置数据库：
#   docker compose down -v
#   cp .env.example .env
#   docker compose up -d --build


# 环境
NODE_ENV=production

# 用户前端构建环境（web 镜像）：production | demo | development
# 公网演示站可设为 demo；本地 yarn dev 无需配置（自动为 development）
# VITE_APP_ENV=demo

# gateway 容器（公网 HTTP 入口，按域名分流 web / admin-web）
GATEWAY_BIND=0.0.0.0
GATEWAY_PORT=80
API_BIND_PORT=3000
MONGO_BIND_PORT=27017
CRAWLER_BIND_PORT=3100

# MongoDB（容器内服务名）
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_DATABASE=app

# Mongo root（用于开启认证；后端也将直接复用 root 账号连接，最简但权限较大）
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=replace_with_strong_password


MONGODB_USERNAME=root
MONGODB_PASSWORD=replace_with_strong_password

# 官方信源种子（容器内路径；compose 已将 ./data 挂载到 /data）
BUILTIN_CATALOG_PATH=/data/built-in-catalog.json

# JWT（生产必须）
JWT_SECRET=replace_with_long_random_string
JWT_EXPIRES_IN=7d

# 邮件 SMTP（注册/登录/重置密码验证码；未配置则验证码仅写后端日志）
# MAIL_HOST=smtp.qiye.aliyun.com
# MAIL_PORT=465
# MAIL_SECURE=true
# MAIL_USER=
# MAIL_PASSWORD=
# MAIL_FROM=ClueArk<noreply@example.com>

# 首个超级管理员（生产必须设置强密码）
ADMIN_EMAIL=admin@clueark.local
ADMIN_PASSWORD=replace_with_strong_password

# 爬虫上报密钥（crawler 默认启动，必须与主站一致）
CRAWLER_INGEST_SECRET=replace_with_strong_secret

# POST /api/crawl/run 手动触发爬虫的密钥（建议生产设置）
CRAWLER_SECRET=replace_with_strong_secret

# DeepSeek / Embedding
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
#
# FEED_EMBEDDING_API_KEY=
# FEED_EMBEDDING_BASE_URL=https://api.openai.com/v1
# FEED_EMBEDDING_MODEL=text-embedding-3-small

# Redis（BullMQ 队列；Compose 内服务名 redis）
REDIS_URL=redis://redis:6379

# Qdrant 向量库（Compose 内服务名 qdrant）
QDRANT_URL=http://qdrant:6333
QDRANT_BIND_PORT=6333
QDRANT_COLLECTION_FEED=feed_items
QDRANT_COLLECTION_MONITORS=monitors

# 队列与匹配（详见 backend/.env.example）
# QUEUE_PIPELINE_CONCURRENCY=5
# SOURCE_POLL_DEFAULT_SEC=600
# SOURCE_POLL_MIN_SEC=30

# Feed 拉取（RSS / 热点）：开关项见仓库 backend/.env.example 中 FEED_RSS_*、FEED_NEWSONW_*。

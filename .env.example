
# 首次部署/重置数据库：
#   docker compose down -v
#   cp .env.example .env
#   docker compose up -d --build


# 环境
NODE_ENV=production

# 端口映射（对外）
WEB_PORT=8080
API_BIND_PORT=3000
MONGO_BIND_PORT=27017
CRAWLER_BIND_PORT=3100

# MongoDB（容器内服务名）
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_DATABASE=app

# Mongo root（用于开启认证；后端也将直接复用 root 账号连接，最简但权限较大）
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=replace_with_strong_password


MONGODB_USERNAME=root
MONGODB_PASSWORD=replace_with_strong_password

# 官方信源种子（容器内路径；compose 已将 ./data 挂载到 /data）
BUILTIN_CATALOG_PATH=/data/built-in-catalog.json

# JWT（生产必须）
JWT_SECRET=replace_with_long_random_string
JWT_EXPIRES_IN=7d

# 首个超级管理员（生产必须设置强密码）
ADMIN_EMAIL=admin@clueark.local
ADMIN_PASSWORD=replace_with_strong_password

# 默认演示账号（启动时若邮箱不存在则创建；不需要可设 DEMO_BOOTSTRAP=false）
DEMO_EMAIL=show@clueark.com
DEMO_PASSWORD=replace_with_strong_password

# 爬虫上报密钥（crawler 默认启动，必须与主站一致）
CRAWLER_INGEST_SECRET=replace_with_strong_secret

# POST /api/crawl/run 手动触发爬虫的密钥（建议生产设置）
CRAWLER_SECRET=replace_with_strong_secret

# DeepSeek / Embedding（可选，不配则跳过相关能力）
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
#
# FEED_EMBEDDING_API_KEY=
# FEED_EMBEDDING_BASE_URL=https://api.openai.com/v1
# FEED_EMBEDDING_MODEL=text-embedding-3-small

# Feed 拉取（RSS / 热点）：开关项见仓库 backend/.env.example 中 FEED_RSS_*、FEED_NEWSONW_*。

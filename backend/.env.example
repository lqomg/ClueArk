NODE_ENV=development
PORT=3000

JWT_SECRET=replace_with_long_random_string
JWT_EXPIRES_IN=7d

MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DATABASE=app
# MONGODB_USERNAME=
# MONGODB_PASSWORD=

# 官方信源种子 JSON（默认：仓库根 data/built-in-catalog.json，可不设）
# BUILTIN_CATALOG_PATH=/absolute/path/to/built-in-catalog.json

# 若库中尚无任何 role=admin 的用户，则创建首个超级管理员：
ADMIN_EMAIL=admin@clueark.local
# 开发环境可省略，将使用默认密码并在日志中警告；生产环境必须设置强密码
ADMIN_PASSWORD=


# 默认演示账号（role=demo）：启动时若该邮箱不存在则创建；也可在「用户管理」中额外新建演示用户
DEMO_EMAIL=show@clueark.com
# 开发环境可省略，将使用默认密码并在日志中警告；生产环境请设置强密码
DEMO_PASSWORD=

# 爬虫服务：须与爬虫侧 CRAWLER_INGEST_SECRET 一致
# GET /api/internal/feed-items/crawl-sources — 拉取 Web 信源（每条含 sourceId、listUrl=crawlListUrl??url、可选 selectors）
# POST /api/internal/feed-items/crawl-ingest — 上报条目
# Header: Authorization: Bearer <值> 或 x-crawler-ingest-secret: <值>
# CRAWLER_INGEST_SECRET=

# DeepSeek（OpenAI 兼容 API），用于动态条目标签与推荐理由；未配置则跳过富化
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
# 定时富化每轮条数（默认 100，上限见 FeedLlmEnrichService）
# FEED_LLM_POLL_LIMIT=100

# 进程启动后默认异步拉一轮 RSS（不阻塞 HTTP listen）；多副本滚动发布可设为 true 跳过启动拉取
# FEED_RSS_POLL_STARTUP_DISABLED=true
# 定时任务中禁用 RSS 轮询（启动拉取仍受 FEED_RSS_POLL_STARTUP_DISABLED 控制）
# FEED_RSS_POLL_DISABLED=true

# 热点 API（信源 kind=hot_api；默认 endpointTemplate=/api/s?id={platformId}）；与信源内 pollIntervalSec 双重要节制
# FEED_NEWSONW_POLL_STARTUP_DISABLED=true
# FEED_NEWSONW_POLL_DISABLED=true

# 进程启动后异步执行一轮富化 + 整点聚类逻辑（不阻塞 HTTP listen）
# FEED_BOOTSTRAP_ENRICH_CLUSTER=true
# FEED_BOOTSTRAP_ENRICH_LIMIT=100

# 相似报道聚类（OpenAI 兼容 /v1/embeddings）；未配置则跳过聚类定时任务
# FEED_EMBEDDING_API_KEY=
# FEED_EMBEDDING_BASE_URL=https://api.openai.com/v1
# FEED_EMBEDDING_MODEL=text-embedding-3-small
# 聚类时单次 embedding 批量（阿里云 v4 等通常≤10；未设默认 10，OpenAI 可设 64）
# FEED_EMBEDDING_BATCH_SIZE=10
# FEED_CLUSTER_CRON_DISABLED=true
# FEED_CLUSTER_LOOKBACK_DAYS=7
# FEED_CLUSTER_MAX_ITEMS=2500
# FEED_CLUSTER_MAX_PAIR_HOURS=12
# FEED_CLUSTER_SIM_TITLE=0.65
# FEED_CLUSTER_SIM_FULL=0.60
# 管理员可在后台「聚合策略」写入库；有记录时优先于上述 FEED_CLUSTER_* / FEED_EMBEDDING_BATCH_SIZE / FEED_CLUSTER_CRON 语义（定时是否执行读库）


# —— 用户「监控」话题（依赖 FEED_EMBEDDING_* 与 LLM；创建失败时请检查 embedding / DEEPSEEK_*）
# 创建时 LLM 最多推荐的信源数（1～50，默认 20）
# 创建监控时 LLM 至少选择的信源数（需 ≤ 启用信源总数且 ≤ MONITOR_MAX_SOURCES）
# MONITOR_MIN_SOURCES=10
# MONITOR_MAX_SOURCES=20
# 时间线候选池单次查询上限（100～20000，默认 3000）；越大越全但更耗内存与 CPU
# MONITOR_TIMELINE_CANDIDATE_CAP=3000
# 未传 recentHours 时默认回溯小时数（1～2160，默认 720）
# MONITOR_DEFAULT_RECENT_HOURS=720
# 创建监控时喂给 LLM 的信源目录条数上限（20～500，默认 200）
# MONITOR_LLM_SOURCE_CATALOG_CAP=200


# —— 监控研判摘要（异步定时 + Mongo 溯源；首期 weekly_rolling 滑动窗）
# 指纹未变仍插入 skipped 记录（审计用，默认 false）
# MONITOR_BRIEF_LOG_SKIPPED=false

# weekly_rolling 滑动窗小时数（1～2160）
# MONITOR_BRIEF_WEEKLY_ROLLING_HOURS=168

# 参与 LLM 的证据条数上限（去重后，3～40，默认 14）
# MONITOR_BRIEF_EVIDENCE_CAP=14

# 每条证据 summary 截断（80～4000，默认 480）
# MONITOR_BRIEF_SUMMARY_MAX_CHARS=480

# 每条证据 recommendReason 截断（0 表示不传，默认 240）
# MONITOR_BRIEF_RECOMMEND_MAX_CHARS=240
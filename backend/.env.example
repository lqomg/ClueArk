NODE_ENV=development
PORT=3000

# 控制台日志级别（默认 info）；排查任务流水线时可设为 debug
# LOG_LEVEL=debug

# 邮件（SMTP）。未配置时验证码仅写入后端日志，便于本地开发；生产环境请填写完整。
# 阿里企业邮箱示例：MAIL_HOST=smtp.qiye.aliyun.com  MAIL_PORT=465  MAIL_SECURE=true
# MAIL_FROM 支持 `显示名<发信地址>` 或纯邮箱
# MAIL_HOST=
# MAIL_PORT=465
# MAIL_SECURE=true
# MAIL_USER=
# MAIL_PASSWORD=
# MAIL_FROM=ClueArk<noreply@example.com>

JWT_SECRET=replace_with_long_random_string
JWT_EXPIRES_IN=7d

# 用户未设置或库中无 timeZone 字段时的回退 IANA（须为有效时区名）
APP_DEFAULT_TIMEZONE=Asia/Shanghai

MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DATABASE=app
# MONGODB_USERNAME=
# MONGODB_PASSWORD=

# 官方信源种子 JSON（默认：仓库根 data/built-in-catalog.json，可不设）
# BUILTIN_CATALOG_PATH=/absolute/path/to/built-in-catalog.json

# 若库中尚无任何 role=admin 的用户，则创建首个超级管理员：
ADMIN_EMAIL=admin@clueark.local
# 开发环境可省略，将使用默认密码并在日志中警告；生产环境必须设置强密码
ADMIN_PASSWORD=


# 爬虫服务：须与爬虫侧 CRAWLER_INGEST_SECRET 一致
# GET /api/internal/feed-items/crawl-sources — 拉取 Web 信源（每条含 sourceId、listUrl=crawlListUrl??url、可选 selectors）
# POST /api/internal/feed-items/crawl-ingest — 上报条目
# Header: Authorization: Bearer <值> 或 x-crawler-ingest-secret: <值>
# CRAWLER_INGEST_SECRET=

# DeepSeek（OpenAI 兼容 API），监控创建与条目富化必填（启动仅校验 key 存在）
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
# LLM 富化仅经 enrich_llm 队列（pipeline 匹配后入队）；管理员可 POST /feed-items/llm/enrich-pending 补救入队
# FEED_LLM_SUMMARY_MAX_CHARS=3000

# Embedding（OpenAI 兼容 /v1/embeddings），监控与 pipeline 必填（启动仅校验 key 存在）
# FEED_EMBEDDING_API_KEY=
# FEED_EMBEDDING_BASE_URL=https://api.openai.com/v1
# FEED_EMBEDDING_MODEL=text-embedding-3-small
# 向量维度（须与 Qdrant 集合一致；text-embedding-v4 默认 1024，未指定时本项默认 1536）
# FEED_EMBEDDING_DIMENSIONS=1536

# 增量事件簇（process_new_item pipeline）；管理员可在后台「事件簇策略」写入库，有记录时优先于下列 env
# EVENT_CLUSTER_LOOKBACK_DAYS=7
# EVENT_CLUSTER_MAX_PAIR_HOURS=48
# PIPELINE_EVENT_SIM_TITLE=0.92
# PIPELINE_CLUSTER_CANDIDATE_CAP=300

# —— Redis / Qdrant / 队列（监控优先架构，均为启动必填）
REDIS_URL=redis://localhost:6379
# 本地 npm run dev 会同时起 API 与 worker；@Cron 扫描入队仅在 worker；crawl_web 由 crawler 进程消费
# 任务审计主数据：MongoDB jobs 集合；GET /api/admin/jobs
QDRANT_URL=http://localhost:6333
# Embedding / LLM（启动时校验已配置，不探活 API）
FEED_EMBEDDING_API_KEY=
DEEPSEEK_API_KEY=
QDRANT_COLLECTION_FEED=feed_items
QDRANT_COLLECTION_MONITORS=monitors
QUEUE_INGEST_CONCURRENCY=3
QUEUE_PIPELINE_CONCURRENCY=5
QUEUE_ENRICH_CONCURRENCY=3
QUEUE_SNAPSHOT_CONCURRENCY=3
QUEUE_BRIEF_CONCURRENCY=2
QUEUE_CRAWL_CONCURRENCY=2
JOB_RETENTION_DAYS=90
QUEUE_EMBED_BATCH_SIZE=8
SOURCE_POLL_SCHEDULER_TICK_SEC=15
SOURCE_POLL_DEFAULT_SEC=600
SOURCE_POLL_MIN_SEC=30
SOURCE_POLL_MAX_SEC=86400
# 通知按 monitorId:clusterId 去重（pipeline 增量聚簇）；建议关闭旧冷却避免不同事件被误挡
NOTIFICATION_COOLDOWN_DISABLED=true
NOTIFICATION_COOLDOWN_SEC=300

MONITOR_SNAPSHOT_DEFAULT_RECENT_HOURS=720
MONITOR_BACKFILL_HOURS=72
MONITOR_SNAPSHOT_CRON=*/5 * * * *

# —— 用户「监控」话题
# 时间线候选池单次查询上限（100～20000，默认 3000）；越大越全但更耗内存与 CPU
# MONITOR_TIMELINE_CANDIDATE_CAP=3000

# 未传 recentHours 时默认回溯小时数（1～2160，默认 720）
# MONITOR_DEFAULT_RECENT_HOURS=720

# 创建监控时喂给 LLM 的信源目录条数上限（20～500，默认 200）
# MONITOR_LLM_SOURCE_CATALOG_CAP=200


# —— 监控研判摘要（异步定时 + Mongo 溯源；首期 weekly_rolling 滑动窗）
# 指纹未变仍插入 skipped 记录（审计用，默认 false）
# MONITOR_BRIEF_LOG_SKIPPED=false

# weekly_rolling 滑动窗小时数（1～2160）
# MONITOR_BRIEF_WEEKLY_ROLLING_HOURS=168

# 参与 LLM 的证据条数上限（去重后，3～40，默认 14）
# MONITOR_BRIEF_EVIDENCE_CAP=14

# 每条证据 summary 截断（80～4000，默认 480）
# MONITOR_BRIEF_SUMMARY_MAX_CHARS=480

# 每条证据 recommendReason 截断（0 表示不传，默认 240）
# MONITOR_BRIEF_RECOMMEND_MAX_CHARS=240
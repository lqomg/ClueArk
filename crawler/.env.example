NODE_ENV=development
PORT=3100

# POST /api/crawl/run：Authorization: Bearer <值> 或 x-crawler-secret: <值>
CRAWLER_SECRET=

# 与主站 backend 共用 Redis；消费 crawl 队列中的 crawl_web 任务
REDIS_URL=redis://localhost:6379
QUEUE_CRAWL_CONCURRENCY=2

# 上报 ingest / 任务状态（须与主站 CRAWLER_INGEST_SECRET 一致）
CLUEARK_BACKEND_URL=http://localhost:3000
CRAWLER_INGEST_SECRET=


# 每信源最多条目（1～200，默认 50）
# CRAWLER_MAX_ITEMS=50
